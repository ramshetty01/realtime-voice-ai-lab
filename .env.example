APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_VOICE_WS_URL=ws://127.0.0.1:8000/ws/voice
DATABASE_URL=sqlite:///./data/voice_lab.db
NVIDIA_NIM_API_KEY=
NGC_API_KEY=
LOCAL_NIM_CACHE=~/.cache/nim
NVIDIA_NIM_IMAGE=nvcr.io/nim/nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:latest
NVIDIA_NIM_BASE_URL=http://127.0.0.1:8001/v1
NVIDIA_NIM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
ASR_MODEL=base
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_AUDIO_SUFFIX=.webm
ASR_TIMEOUT_SECONDS=30
LLM_TIMEOUT_SECONDS=45
TTS_TIMEOUT_SECONDS=30
MAX_HISTORY_TURNS=8
MAX_AUDIO_BYTES=10485760
PIPER_BIN=piper
PIPER_MODEL_PATH=./models/piper/default.onnx
AUDIO_PERSISTENCE_ENABLED=false
